{
    "name": "bdd-step-architect",
    "displayName": "BDD Step Architect",
    "description": "Smart BDD Assistant for Playwright and TypeScript",
    "version": "0.0.9",
    "publisher": "Puk3p",
    "icon": "icons/logo.png",
    "author": {
        "name": "Lupu George"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Puk3p/bdd-step-architect"
    },
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Testing",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:feature",
        "onLanguage:typescript"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "bdd-step-architect.insertStep",
                "title": "BDD: Insert Step Definition"
            },
            {
                "command": "bdd-step-architect.insertStepFromCatalog",
                "title": "Insert Step",
                "icon": "$(add)"
            },
            {
                "command": "bdd-step-architect.jumpToStep",
                "title": "Jump to Step"
            },
            {
                "command": "bdd-step-architect.renameStep",
                "title": "✏️ Edit / Rename Step"
            },
            {
                "command": "bdd-step-architect.findUnusedSteps",
                "title": "BDD: Find Unused Steps (Dead Code)",
                "icon": "$(trash)"
            },
            {
                "command": "bdd-step-architect.generateBulkSteps",
                "title": "BDD: Generate Bulk Steps"
            },
            {
                "command": "bdd-step-architect.searchSteps",
                "title": "BDD: Search Step Definitions",
                "icon": "$(search)"
            },
            {
                "command": "bdd-step-architect.showFeatureGraph",
                "title": "BDD: Visualize Feature Graph",
                "icon": "$(type-hierarchy)"
            }
        ],
        "menus": {
            "view/item/context": [
                {
                    "command": "bdd-step-architect.renameStep",
                    "when": "view == bddStepCatalog && viewItem == step",
                    "group": "inline"
                }
            ],
            "editor/title": [
                {
                    "command": "bdd-step-architect.showFeatureGraph",
                    "when": "resourceExtname == .feature",
                    "group": "navigation"
                }
            ],
            "view/title": [
                {
                    "command": "bdd-step-architect.searchSteps",
                    "when": "view == bddStepCatalog",
                    "group": "navigation"
                },
                {
                    "command": "bdd-step-architect.findUnusedSteps",
                    "when": "view == bddStepCatalog",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "BDD Step Architect",
            "properties": {
                "bddStepArchitect.stepsImportPath": {
                    "type": "string",
                    "default": "src/steps/bdd",
                    "description": "The path used to import Gherkin keywords (Given, When, Then)."
                },
                "bddStepArchitect.worldImportPath": {
                    "type": "string",
                    "default": "src/support/worlds/UnifiedWorld",
                    "description": "The path used to import the UnifiedWorld interface/class."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "bdd-step-architect-explorer",
                    "title": "BDD Step Architect",
                    "icon": "icons/logo.png"
                }
            ]
        },
        "views": {
            "bdd-step-architect-explorer": [
                {
                    "id": "bddStepCatalog",
                    "name": "Step Catalog"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "format": "prettier --write \"src/**/*.ts\" \"*.mjs\" \"*.json\" --ignore-path .prettierignore",
        "format:check": "prettier --check \"src/**/*.ts\" \"*.mjs\" \"*.json\" --ignore-path .prettierignore",
        "test": "vscode-test",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.105.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
