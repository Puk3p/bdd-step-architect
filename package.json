{
    "name": "bdd-step-architect",
    "displayName": "BDD Step Architect",
    "description": "Smart BDD Assistant for Playwright and TypeScript",
    "version": "0.0.4",
    "publisher": "Puk3p",
    "icon": "icons/logo.png",
    "author": {
        "name": "Lupu George"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Puk3p/bdd-step-architect"
    },
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Testing",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:feature",
        "onLanguage:typescript"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "bdd-step-architect.insertStep",
                "title": "BDD: Insert Step Definition"
            }
        ],
        "configuration": {
            "title": "BDD Step Architect",
            "properties": {
                "bddStepArchitect.stepsImportPath": {
                    "type": "string",
                    "default": "src/steps/bdd",
                    "description": "The path used to import Gherkin keywords (Given, When, Then)."
                },
                "bddStepArchitect.worldImportPath": {
                    "type": "string",
                    "default": "src/support/worlds/UnifiedWorld",
                    "description": "The path used to import the UnifiedWorld interface/class."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src",
        "format": "prettier --write \"src/**/*.ts\" \"*.mjs\" \"*.js\" \"*.json\" --ignore-path .prettierignore",
        "format:check": "prettier --check \"src/**/*.ts\" \"*.mjs\" \"*.js\" \"*.json\" --ignore-path .prettierignore",
        "test": "vscode-test",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.105.0",
        "@vscode/test-cli": "^0.0.11",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
